generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────── جداول مرجعية ────────────────

model Governorate {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  institutions Institution[]
  warehouses   Warehouse[]
}

model Department {
  id         Int              @id @default(autoincrement())
  key        String           @unique
  labelAr    String
  color      String           @default("#64748b")
  icon       String           @default("folder")
  warehouses Warehouse[]
  requests   Request[]
  items      DepartmentItem[]
}

model Unit {
  id      Int    @id @default(autoincrement())
  name    String @unique
}

model Priority {
  id      Int    @id @default(autoincrement())
  key     String @unique
  labelAr String
  color   String @default("#64748b")
  level   Int    @default(1)
}

model InstitutionType {
  id      Int    @id @default(autoincrement())
  key     String @unique
  labelAr String
}

model DepartmentItem {
  id           Int        @id @default(autoincrement())
  key          String
  labelAr      String
  defaultUnit  String     @default("قطعة")
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  departmentId Int

  @@unique([key, departmentId])
}

// ──────────────── المستخدمين ────────────────

enum UserType {
  admin
  institution
  warehouse
}

model User {
  id            Int          @id @default(autoincrement())
  email         String       @unique
  passwordHash  String
  userType      UserType
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  institution   Institution? @relation(fields: [institutionId], references: [id])
  institutionId Int?         @unique
  warehouse     Warehouse?   @relation(fields: [warehouseId], references: [id])
  warehouseId   Int?         @unique
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String
  title     String
  body      String?
  read      Boolean  @default(false)
  linkType  String?
  linkId    String?
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([createdAt])
}

model RequestComment {
  id        Int      @id @default(autoincrement())
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  requestId Int
  userId    Int
  userEmail String
  userType  String
  body      String
  createdAt DateTime @default(now())

  @@index([requestId])
}

model Institution {
  id              Int         @id @default(autoincrement())
  name            String
  institutionType String
  governorate     Governorate @relation(fields: [governorateId], references: [id])
  governorateId   Int
  user            User?
  requests        Request[]
  deletedAt       DateTime?

  @@unique([name, governorateId])
  @@index([deletedAt])
}

model Warehouse {
  id            Int             @id @default(autoincrement())
  name          String
  department    Department      @relation(fields: [departmentId], references: [id])
  departmentId  Int
  governorate   Governorate     @relation(fields: [governorateId], references: [id])
  governorateId Int
  user          User?
  requests      Request[]
  inventory     InventoryItem[]
  deletedAt     DateTime?

  @@unique([departmentId, governorateId])
  @@index([deletedAt])
}

// ──────────────── الطلبات ────────────────

// Priority enum تم استبداله بجدول Priority (ديناميكي)

enum RequestStatus {
  draft
  pending
  in_progress
  ready_for_pickup
  completed
  rejected
  cancelled
  undelivered
}

model Request {
  id               Int           @id @default(autoincrement())
  title            String
  description      String
  impact           String?
  priority         String
  status           RequestStatus @default(draft)
  quantity         Int
  studentsAffected Int           @default(0)
  unitType         String        @default("متنوع")
  subcategory      String

  dateSubmitted    DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  institution      Institution   @relation(fields: [institutionId], references: [id])
  institutionId    Int
  department       Department    @relation(fields: [departmentId], references: [id])
  departmentId     Int
  warehouse        Warehouse     @relation(fields: [warehouseId], references: [id])
  warehouseId      Int

  requestedItems   RequestItem[]
  comments         RequestComment[]

  rejectionReason    String?
  rejectionDate      DateTime?
  cancellationReason String?
  cancellationDate   DateTime?
  cancellationType   String?

  attachments Json?
  deletedAt   DateTime?

  @@index([institutionId])
  @@index([warehouseId])
  @@index([status])
  @@index([deletedAt])
}

model RequestItem {
  id          Int     @id @default(autoincrement())
  itemName    String
  originalKey String
  quantity    Int
  unitType    String
  displayText String

  request   Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
  requestId Int
}

// ──────────────── المخزون ────────────────

model InventoryItem {
  id           Int    @id @default(autoincrement())
  name         String
  category     String
  quantity     Int
  unitType     String
  minThreshold Int    @default(5)
  department   String

  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  warehouseId Int

  @@unique([name, department, warehouseId])
}

// ──────────────── سجل الأحداث (Audit Log) ────────────────

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int?
  userEmail  String
  action     String
  entityType String
  entityId   String?
  payload    Json?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([entityType])
  @@index([userId])
}

// ──────────────── طلبات استعادة كلمة المرور ────────────────

model PasswordResetRequest {
  id           Int       @id @default(autoincrement())
  userId       Int
  userEmail    String
  status       String    @default("pending")
  requestedAt  DateTime  @default(now())
  resolvedAt   DateTime?
  newPassword  String?

  @@index([status])
  @@index([userId])
}

// ──────────────── التقارير الشهرية ────────────────

model MonthlyReport {
  id                    Int      @id @default(autoincrement())
  month                 Int
  year                  Int
  generatedDate         DateTime @default(now())
  institutionName       String
  totalRequests         Int
  completedRequests     Int
  pendingRequests       Int
  inProgressRequests    Int
  totalItems            Int
  totalStudentsAffected Int

  @@unique([month, year, institutionName])
}
